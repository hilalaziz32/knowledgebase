# Copy to .env and fill in. Every agent loads this.

# Postgres connection string for the Evergreen Supabase DB (pooler or direct URL)
SUPABASE_DB_URL=postgresql://postgres.<project>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# Gemini — used for BOTH the LLM extraction and the embeddings.
GEMINI_API_KEY=
# LLM model for extraction/parsing (judgment work).
GEMINI_LLM_MODEL=gemini-2.5-flash
# Embedding model MUST match the search side. Do not change without re-embedding everything.
GEMINI_EMBED_MODEL=gemini-embedding-001

# Airtable — used to read campaigns/copy/metrics by client id, and to confirm the client record.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
